#: ../../04-data.rst:3
msgid "资源文件说明"
msgstr "Description of Resource Files"

#: ../../04-data.rst:7
msgid "``dict.txt`` 文件的作用"
msgstr "Role of the ``dict.txt`` file"

#: ../../04-data.rst:9
msgid ":file:`dict.txt` 是 ``jieba`` 分词的主词典文件，包含约 349,047 行词条。"
msgstr ":file:`dict.txt` is the main dictionary file for ``jieba`` segmentation, containing approximately 349,047 entries."

#: ../../04-data.rst:11
msgid "人工维护和整理的静态资源文件"
msgstr "Manually maintained and organized static resource files"

#: ../../04-data.rst:12
msgid "基于大规模中文语料库统计得出"
msgstr "Statistically derived from large-scale Chinese corpora"

#: ../../04-data.rst:13
msgid "开发者手动更新和维护"
msgstr "Manually updated and maintained by developers"

#: ../../04-data.rst:15
msgid "每一行的格式为："
msgstr "Format for each line:"

#: ../../04-data.rst:17
msgid "词语 词频 词性"
msgstr "Word Frequency Part-of-Speech"

#: ../../04-data.rst:19
msgid "词语：中文词汇"
msgstr "Word: Chinese vocabulary"

#: ../../04-data.rst:20
msgid "词频：该词在语料库中出现的频率（数字越大越常见）"
msgstr "Frequency: The frequency of the word in the corpus (larger numbers are more common)"

#: ../../04-data.rst:21
msgid "词性：词语的词性标记（如 n=名词, m=数词, nz=其他专名等）"
msgstr "Part-of-Speech: The POS tag of the word (e.g., n=noun, m=numeral, nz=other proper name, etc.)"

#: ../../04-data.rst:25
msgid "``dict.txt`` 与 ``finalseg`` / ``posseg`` 的关系"
msgstr "Relationship between ``dict.txt`` and ``finalseg`` / ``posseg``"

#: ../../04-data.rst:27
msgid "它们有关系 but 职责不同："
msgstr "They are related but have different responsibilities:"

